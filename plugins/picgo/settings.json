{
  "version": 2,
  "title": "图床设置",
  "description": "配置默认图床、上传格式、文件名策略、链接插入格式等选项。",
  "fields": [
    {
      "key": "defaultProvider",
      "label": "默认图床",
      "type": "select",
      "options": [
        { "value": "smms", "label": "SM.MS" },
        { "value": "imgur", "label": "Imgur" },
        { "value": "github", "label": "GitHub" },
        { "value": "tencent", "label": "腾讯云 COS" },
        { "value": "aliyun", "label": "阿里云 OSS" },
        { "value": "qiniu", "label": "七牛云" },
        { "value": "upyun", "label": "又拍云" },
        { "value": "minio", "label": "MinIO (S3 兼容)" },
        { "value": "custom", "label": "自定义端点" }
      ],
      "default": "smms",
      "required": true,
      "description": "选择默认图床。可在右侧面板顶部临时切换。"
    },
    {
      "key": "uploadFormat",
      "label": "客户端转码格式",
      "type": "select",
      "options": [
        { "value": "original", "label": "原图（不转码）" },
        { "value": "webp", "label": "WebP（推荐，体积小）" },
        { "value": "jpg", "label": "JPG（兼容性好）" },
        { "value": "png", "label": "PNG（无损）" }
      ],
      "default": "original",
      "required": true,
      "description": "上传前在浏览器内通过 canvas 转换的格式。webp→quality 0.92，jpg→quality 0.85。"
    },
    {
      "key": "maxFileSizeMB",
      "label": "最大文件大小 (MB)",
      "type": "number",
      "default": 10,
      "min": 1,
      "max": 100,
      "required": true,
      "description": "超过此大小的文件会被前端直接拒绝，不会上传到图床。"
    },
    {
      "key": "filenameStrategy",
      "label": "文件名策略",
      "type": "select",
      "options": [
        { "value": "original", "label": "保留原文件名" },
        { "value": "uuid", "label": "UUID（避免冲突）" },
        { "value": "timestamp", "label": "时间戳前缀" }
      ],
      "default": "original",
      "required": true,
      "description": "上传到图床时使用的远程文件名。"
    },
    {
      "key": "linkFormat",
      "label": "插入链接格式",
      "type": "select",
      "options": [
        { "value": "markdown", "label": "Markdown (![name](url))" },
        { "value": "html", "label": "HTML (<img>)" },
        { "value": "url", "label": "裸 URL" }
      ],
      "default": "markdown",
      "required": true,
      "description": "点击「插入到笔记」时写入正文的文本格式。"
    },
    {
      "key": "enableHistory",
      "label": "启用上传历史",
      "type": "boolean",
      "default": true,
      "description": "开启后会在插件 storage 中缓存上传记录，可用于回查与一键再插入。"
    },
    {
      "key": "historyRetention",
      "label": "历史保留条数",
      "type": "number",
      "default": 200,
      "min": 10,
      "max": 2000,
      "required": true,
      "description": "超过此数量时按 FIFO 自动裁剪最早的历史记录。"
    },

    {
      "key": "smmsSection",
      "label": "SM.MS 配置",
      "type": "string",
      "required": false,
      "visibleWhen": { "key": "defaultProvider", "equals": "smms" },
      "description": "留空 Token 表示匿名上传（受 SM.MS 频率限制）。"
    },
    {
      "key": "smmsToken",
      "label": "SM.MS Token",
      "type": "password",
      "secret": true,
      "required": false,
      "visibleWhen": { "key": "defaultProvider", "equals": "smms" },
      "description": "可选；登录 SM.MS 后从用户中心获取的 API Token。"
    },

    {
      "key": "imgurSection",
      "label": "Imgur 配置",
      "type": "string",
      "required": false,
      "visibleWhen": { "key": "defaultProvider", "equals": "imgur" },
      "description": "Imgur 要求必须注册应用并提供 Client-ID。"
    },
    {
      "key": "imgurClientId",
      "label": "Imgur Client-ID",
      "type": "password",
      "secret": true,
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "imgur" }
    },

    {
      "key": "githubSection",
      "label": "GitHub 配置",
      "type": "string",
      "required": false,
      "visibleWhen": { "key": "defaultProvider", "equals": "github" },
      "description": "使用 GitHub 仓库作为图床时需要 Personal Access Token + 仓库信息。"
    },
    {
      "key": "githubToken",
      "label": "GitHub Token",
      "type": "password",
      "secret": true,
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "github" }
    },
    {
      "key": "githubOwner",
      "label": "仓库 Owner",
      "type": "string",
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "github" }
    },
    {
      "key": "githubRepo",
      "label": "仓库名",
      "type": "string",
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "github" }
    },
    {
      "key": "githubBranch",
      "label": "分支",
      "type": "string",
      "default": "main",
      "required": false,
      "visibleWhen": { "key": "defaultProvider", "equals": "github" }
    },
    {
      "key": "githubPathPrefix",
      "label": "路径前缀",
      "type": "string",
      "default": "images/",
      "required": false,
      "visibleWhen": { "key": "defaultProvider", "equals": "github" }
    },

    {
      "key": "customSection",
      "label": "自定义端点配置",
      "type": "string",
      "required": false,
      "visibleWhen": { "key": "defaultProvider", "equals": "custom" },
      "description": "支持任意 HTTP 端点作为图床（WebDAV / S3 兼容 / 自建服务）。"
    },
    {
      "key": "customEndpoint",
      "label": "端点 URL",
      "type": "string",
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "custom" }
    },
    {
      "key": "customMethod",
      "label": "HTTP 方法",
      "type": "select",
      "options": [
        { "value": "POST", "label": "POST" },
        { "value": "PUT", "label": "PUT" }
      ],
      "default": "POST",
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "custom" }
    },
    {
      "key": "customHeaders",
      "label": "自定义请求头",
      "type": "string-multiline",
      "required": false,
      "visibleWhen": { "key": "defaultProvider", "equals": "custom" },
      "description": "每行一个，格式为 `Key: Value`。"
    },
    {
      "key": "customBodyTemplate",
      "label": "请求体模板",
      "type": "string-multiline",
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "custom" },
      "description": "支持占位符 {filename} {base64} {mime} {size}。例如 `{\"filename\":\"{filename}\",\"image\":\"{base64}\"}`。"
    },
    {
      "key": "customResponseUrlPath",
      "label": "响应 URL 字段路径",
      "type": "string",
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "custom" },
      "description": "点分路径，从响应 JSON 中取出图片 URL，如 `data.url`。"
    },

    {
      "key": "tencentSection",
      "label": "腾讯云 COS 配置",
      "type": "string",
      "required": false,
      "visibleWhen": { "key": "defaultProvider", "equals": "tencent" },
      "description": "需要先在腾讯云 CAM 控制台创建 API 密钥（SecretId / SecretKey），并确保存储桶已开通 COS 服务。"
    },
    {
      "key": "tencentSecretId",
      "label": "SecretId",
      "type": "string",
      "secret": true,
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "tencent" }
    },
    {
      "key": "tencentSecretKey",
      "label": "SecretKey",
      "type": "password",
      "secret": true,
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "tencent" }
    },
    {
      "key": "tencentRegion",
      "label": "地域 (Region)",
      "type": "string",
      "default": "ap-guangzhou",
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "tencent" },
      "description": "存储桶所在地域，如 ap-guangzhou / ap-shanghai / ap-beijing / ap-hongkong。"
    },
    {
      "key": "tencentBucket",
      "label": "存储桶 (Bucket)",
      "type": "string",
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "tencent" },
      "placeholder": "example-1250000000"
    },
    {
      "key": "tencentProtocol",
      "label": "访问协议",
      "type": "select",
      "options": [
        { "value": "https", "label": "HTTPS（推荐）" },
        { "value": "http", "label": "HTTP" }
      ],
      "default": "https",
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "tencent" }
    },
    {
      "key": "tencentKeyPrefix",
      "label": "路径前缀",
      "type": "string",
      "default": "images/",
      "required": false,
      "visibleWhen": { "key": "defaultProvider", "equals": "tencent" },
      "description": "上传到 COS 时的对象 Key 前缀，结尾建议带 `/`。"
    },

    {
      "key": "aliyunSection",
      "label": "阿里云 OSS 配置",
      "type": "string",
      "required": false,
      "visibleWhen": { "key": "defaultProvider", "equals": "aliyun" },
      "description": "需要先在阿里云 RAM 控制台创建 AccessKey，并确保 OSS 存储桶已创建且 RAM 策略允许 PutObject。"
    },
    {
      "key": "aliyunAccessKeyId",
      "label": "AccessKey ID",
      "type": "string",
      "secret": true,
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "aliyun" }
    },
    {
      "key": "aliyunAccessKeySecret",
      "label": "AccessKey Secret",
      "type": "password",
      "secret": true,
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "aliyun" }
    },
    {
      "key": "aliyunRegion",
      "label": "地域 (Region)",
      "type": "string",
      "default": "oss-cn-hangzhou",
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "aliyun" },
      "description": "OSS 地域代码，如 oss-cn-hangzhou / oss-cn-shanghai / oss-cn-beijing / oss-cn-shenzhen。"
    },
    {
      "key": "aliyunBucket",
      "label": "存储桶 (Bucket)",
      "type": "string",
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "aliyun" }
    },
    {
      "key": "aliyunEndpoint",
      "label": "自定义 Endpoint（可选）",
      "type": "string",
      "required": false,
      "visibleWhen": { "key": "defaultProvider", "equals": "aliyun" },
      "description": "一般留空，使用默认公网 Endpoint。ECS VPC 或金融云环境需填写内网 Endpoint。"
    },
    {
      "key": "aliyunKeyPrefix",
      "label": "路径前缀",
      "type": "string",
      "default": "images/",
      "required": false,
      "visibleWhen": { "key": "defaultProvider", "equals": "aliyun" }
    },

    {
      "key": "qiniuSection",
      "label": "七牛云配置",
      "type": "string",
      "required": false,
      "visibleWhen": { "key": "defaultProvider", "equals": "qiniu" },
      "description": "需要先在七牛云个人中心创建 AccessKey / SecretKey，并在对象存储控制台创建存储空间。"
    },
    {
      "key": "qiniuAccessKey",
      "label": "AccessKey",
      "type": "string",
      "secret": true,
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "qiniu" }
    },
    {
      "key": "qiniuSecretKey",
      "label": "SecretKey",
      "type": "password",
      "secret": true,
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "qiniu" }
    },
    {
      "key": "qiniuBucket",
      "label": "存储空间 (Bucket)",
      "type": "string",
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "qiniu" }
    },
    {
      "key": "qiniuZone",
      "label": "存储区域 (Zone)",
      "type": "select",
      "options": [
        { "value": "z0", "label": "华东 (z0)" },
        { "value": "z1", "label": "华北 (z1)" },
        { "value": "z2", "label": "华南 (z2)" },
        { "value": "na0", "label": "北美 (na0)" },
        { "value": "as0", "label": "东南亚 (as0)" }
      ],
      "default": "z0",
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "qiniu" },
      "description": "必须与 Bucket 所在区域一致，否则上传会返回 no such bucket。"
    },
    {
      "key": "qiniuDomain",
      "label": "访问域名 (Domain)",
      "type": "string",
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "qiniu" },
      "description": "七牛上传接口不返回完整 URL，使用本字段拼出最终图片地址，如 `http://cdn.example.com`。"
    },
    {
      "key": "qiniuKeyPrefix",
      "label": "路径前缀",
      "type": "string",
      "default": "images/",
      "required": false,
      "visibleWhen": { "key": "defaultProvider", "equals": "qiniu" }
    },

    {
      "key": "upyunSection",
      "label": "又拍云配置",
      "type": "string",
      "required": false,
      "visibleWhen": { "key": "defaultProvider", "equals": "upyun" },
      "description": "需要先在又拍云控制台创建云存储服务，并配置操作员账号（不是又拍云登录密码）。"
    },
    {
      "key": "upyunOperator",
      "label": "操作员",
      "type": "string",
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "upyun" },
      "description": "在又拍云控制台「云存储 → 操作员管理」配置的操作员名。"
    },
    {
      "key": "upyunPassword",
      "label": "操作员密码",
      "type": "password",
      "secret": true,
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "upyun" }
    },
    {
      "key": "upyunBucket",
      "label": "服务名 (Service)",
      "type": "string",
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "upyun" },
      "description": "云存储服务的服务名，不是显示的「存储名」。"
    },
    {
      "key": "upyunDomain",
      "label": "加速域名 (Domain)",
      "type": "string",
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "upyun" },
      "description": "用于拼出最终图片 URL。又拍云上传接口不返回完整 URL。"
    },
    {
      "key": "upyunKeyPrefix",
      "label": "路径前缀",
      "type": "string",
      "default": "",
      "required": false,
      "visibleWhen": { "key": "defaultProvider", "equals": "upyun" }
    },

    {
      "key": "minioSection",
      "label": "MinIO 配置",
      "type": "string",
      "required": false,
      "visibleWhen": { "key": "defaultProvider", "equals": "minio" },
      "description": "自建 / 第三方 MinIO 服务，兼容 AWS S3 协议。需提前创建存储桶并配置访问策略为 read/write。"
    },
    {
      "key": "minioEndpoint",
      "label": "Endpoint",
      "type": "string",
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "minio" },
      "placeholder": "http://localhost:9000",
      "description": "MinIO 服务地址，公网需带协议头。"
    },
    {
      "key": "minioAccessKey",
      "label": "Access Key",
      "type": "string",
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "minio" }
    },
    {
      "key": "minioSecretKey",
      "label": "Secret Key",
      "type": "password",
      "secret": true,
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "minio" }
    },
    {
      "key": "minioBucket",
      "label": "Bucket",
      "type": "string",
      "required": true,
      "visibleWhen": { "key": "defaultProvider", "equals": "minio" }
    },
    {
      "key": "minioRegion",
      "label": "Region",
      "type": "string",
      "default": "us-east-1",
      "required": false,
      "visibleWhen": { "key": "defaultProvider", "equals": "minio" },
      "description": "MinIO 通常不校验 region，保持默认 us-east-1 即可；某些部署需要填写实际区域。"
    },
    {
      "key": "minioUseSsl",
      "label": "使用 HTTPS",
      "type": "boolean",
      "default": false,
      "required": false,
      "visibleWhen": { "key": "defaultProvider", "equals": "minio" }
    },
    {
      "key": "minioPathStyle",
      "label": "Path-Style 访问",
      "type": "boolean",
      "default": true,
      "required": false,
      "visibleWhen": { "key": "defaultProvider", "equals": "minio" },
      "description": "MinIO 默认使用 path-style (URL 中带 bucket 名)。"
    },
    {
      "key": "minioKeyPrefix",
      "label": "路径前缀",
      "type": "string",
      "default": "images/",
      "required": false,
      "visibleWhen": { "key": "defaultProvider", "equals": "minio" }
    }
  ]
}
