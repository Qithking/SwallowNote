{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@/lib/*": ["../../src/lib/*"],
      "@/components/CodeEditor": ["../../src/components/CodeEditor/index.ts"],
      "@/components/CodeEditor/*": ["../../src/components/CodeEditor/*"]
    }
  },
  "include": ["src", "../../docs/plugin-sdk/src"]
}
